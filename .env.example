# =============================================================================
# Docker y producción: copiar a .env
#   docker compose up -d --build
#
# Localhost (npm run dev): copiar .env.development.example → .env.development
# =============================================================================

CRM_FRONT_PORT=3007

# Mismo puerto que PORT en chatbot_api_backend/.env cuando el API corre con npm run dev en el PC.
# El CRM en Docker arma el proxy como host.docker.internal:HOST_API_PORT
HOST_API_PORT=3004

# Opcional: sustituye lo anterior por un destino explícito (host:puerto, sin http://).
# API_UPSTREAM=host.docker.internal:3005
# Con stack en la raíz del monorepo (compose que define api-backend): no hace falta; use api-backend:3001

# En npm run dev, VITE_API_URL define también el proxy de Vite (/api, /socket.io): mismo origen que esta URL.
# VITE_API_URL=http://localhost:3004/api

# URL del backend para WebSocket (mismo servidor que la API). Necesario para que la vista
# previa en vivo (lo que escribe el contacto) se vea en el CRM. Si el CRM está en otro
# puerto que el backend, define una de las dos:
# VITE_WS_URL=http://localhost:3004
# (o VITE_API_URL arriba; el socket usará la misma base)
